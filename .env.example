HA_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_access_token_here
HA_ENTITY_ID=sensor.solar_total_energy

# Fronius Solar.web (optional - alternative or complement to Home Assistant)
# Generate keys in Solar.web -> Settings -> API (Premium account required).
# SOLARWEB_PV_SYSTEM_ID is optional: when omitted and the account holds
# exactly one PV system, it is auto-resolved.
# SOLARWEB_ACCESS_KEY_ID=your_access_key_id
# SOLARWEB_ACCESS_KEY_VALUE=your_access_key_secret
# SOLARWEB_PV_SYSTEM_ID=

PLANT_KWP=10.0

FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=false

# Anonymous instance telemetry: sends a daily heartbeat with version and a
# random instance ID. No user data, no IPs, no HA values. Set to false to opt out.
# TELEMETRY_ENABLED=false
